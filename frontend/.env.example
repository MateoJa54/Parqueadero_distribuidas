# Variables de entorno del frontend (Vite expone solo las que empiezan con VITE_).
# Copia este archivo a ".env" antes de arrancar el frontend:
#   Linux/macOS:  cp .env.example .env
#   Windows:      copy .env.example .env
#
# Todas las llamadas pasan por Kong (gateway :8000): CORS, JWT y rate-limit
# centralizados, igual que en produccion. Kong enruta por path a cada MS.
VITE_API_USUARIOS=http://localhost:8000/api/v1
VITE_API_ZONAS=http://localhost:8000/api/v1
VITE_API_ASIGNACIONES=http://localhost:8000/api/v1
VITE_API_TICKETS=http://localhost:8000/api/v1
VITE_API_VEHICULOS=http://localhost:8000/api/vehiculos
VITE_API_AUDIT=http://localhost:8000/api/v1/audit

# --- Alternativa: cada microservicio directo (requiere CORS propio en cada MS) ---
# VITE_API_USUARIOS=http://localhost:8081/api/v1
# VITE_API_ZONAS=http://localhost:8080/api/v1
# VITE_API_ASIGNACIONES=http://localhost:8082/api/v1
# VITE_API_TICKETS=http://localhost:8083/api/v1
# VITE_API_VEHICULOS=http://localhost:3000/api/vehiculos
# VITE_API_AUDIT=http://localhost:3002/api/v1/audit
