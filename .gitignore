# ============================================================
#  .gitignore raiz - Sistema de Parqueadero (microservicios)
# ============================================================

# ---------- Java / Maven (usuarios, zonas) ----------
target/
*.class
*.jar
*.war
*.ear
!**/.mvn/wrapper/maven-wrapper.jar
.mvn/.develocity/
*.log

# ---------- Node / NestJS (vehiculos) ----------
node_modules/
dist/
build/
coverage/
.npm/
*.tsbuildinfo
.eslintcache

# ---------- Variables de entorno / secretos ----------
.env
.env.*
!.env.example

# ---------- Claves JWT (RS256) ----------
# La clave PRIVADA jamas se versiona (solo usuarios la usa para firmar).
# La clave PUBLICA puede compartirse; se genera con scripts/setup_jwt_keys.sh.
keys/jwt_private.pem
keys/jwt_public.pem
keys/*.p8
keys/*.key

# ---------- IDE / Editor ----------
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.classpath
.project
.settings/
*.swp

# ---------- Sistema operativo ----------
.DS_Store
Thumbs.db

# ---------- Docker ----------
*.pid


# ---------- Herramientas locales (no versionar binarios sueltos) ----------
kubectl

# ---------- SonarQube / analisis estatico ----------
.scannerwork/
.sonar/

# ---------- SDD / Engram ----------
.atl/
