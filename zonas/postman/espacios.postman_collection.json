{
  "info": {
    "name": "Espacios API - Parqueadero",
    "description": "Coleccion dedicada a la gestion de ESPACIOS (Spring Boot, servicio zonas, puerto 8080).\n\nEsta organizada en carpetas:\n  0. Preparacion  -> crea una zona base para alojar los espacios\n  1. CRUD Espacios\n  2. Estados y disponibilidad\n  3. Reglas de negocio y errores\n  4. Limpieza\n\nVariables:\n  - urlZonas: base del servicio (fallback http://localhost:8080). Si activas el environment 'Parqueadero - Local', se usa esa.\n  - Los IDs se guardan solos en variables de coleccion.\n\nEnums: TipoEspacio (MOTO, AUTO, BUSETA) | EstadoEspacio (DISPONIBLE, OCUPADO, RESERVADO, MANTENIMIENTO).\nEjecutable de corrido con 'Run collection'.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "urlZonas", "value": "http://localhost:8080", "type": "string" },
    { "key": "idZona", "value": "", "type": "string" },
    { "key": "idEspacio", "value": "", "type": "string" },
    { "key": "idZonaCap", "value": "", "type": "string" },
    { "key": "nombreZonaTmp", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "0. Preparacion",
      "item": [
        {
          "name": "Crear Zona base (capacidad 5)",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [ "pm.collectionVariables.set('nombreZonaTmp', 'Zona ESP ' + Date.now());" ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 201', () => pm.response.code === 201);", "pm.collectionVariables.set('idZona', pm.response.json().idZona);", "console.log('idZona:', pm.collectionVariables.get('idZona'));" ] } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"{{nombreZonaTmp}}\",\n  \"descripcion\": \"Zona base para pruebas de espacios\",\n  \"tipo\": \"REGULAR\",\n  \"capacidad\": 5\n}" },
            "url": { "raw": "{{urlZonas}}/api/v1/zonas", "host": ["{{urlZonas}}"], "path": ["api", "v1", "zonas"] }
          },
          "response": []
        }
      ]
    },
    {
      "name": "1. CRUD Espacios",
      "item": [
        {
          "name": "Crear Espacio (201)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 201', () => pm.response.code === 201);", "const b = pm.response.json();", "pm.collectionVariables.set('idEspacio', b.id);", "pm.test('codigo generado ESP-', () => b.codigo.startsWith('ESP-'));", "pm.test('estado inicial DISPONIBLE', () => b.estado === 'DISPONIBLE');", "pm.test('activo true', () => b.activo === true);" ] } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idZona\": \"{{idZona}}\",\n  \"descripcion\": \"Espacio para auto\",\n  \"tipo\": \"AUTO\"\n}" },
            "url": { "raw": "{{urlZonas}}/api/v1/espacios", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios"] }
          },
          "response": []
        },
        {
          "name": "Listar Espacios (200)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 200', () => pm.response.code === 200);", "pm.test('es lista', () => Array.isArray(pm.response.json()));" ] } } ],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios"] } },
          "response": []
        },
        {
          "name": "Obtener Espacio por ID (200)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 200', () => pm.response.code === 200);" ] } } ],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/{{idEspacio}}", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "{{idEspacio}}"] } },
          "response": []
        },
        {
          "name": "Actualizar Espacio (PUT 200)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 200', () => pm.response.code === 200);", "pm.test('tipo a BUSETA', () => pm.response.json().tipo === 'BUSETA');" ] } } ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idZona\": \"{{idZona}}\",\n  \"descripcion\": \"Reasignado a buseta\",\n  \"tipo\": \"BUSETA\"\n}" },
            "url": { "raw": "{{urlZonas}}/api/v1/espacios/{{idEspacio}}", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "{{idEspacio}}"] },
            "description": "Solo actualiza descripcion y tipo. El codigo, la zona y el estado/activo no cambian por aqui."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Estados y disponibilidad",
      "item": [
        {
          "name": "Cambiar a OCUPADO (200)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 200', () => pm.response.code === 200);", "pm.test('estado OCUPADO', () => pm.response.json().estado === 'OCUPADO');" ] } } ],
          "request": { "method": "PATCH", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/{{idEspacio}}/estado?estado=OCUPADO", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "{{idEspacio}}", "estado"], "query": [{ "key": "estado", "value": "OCUPADO" }] } },
          "response": []
        },
        {
          "name": "Listar por estado OCUPADO (200)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 200', () => pm.response.code === 200);" ] } } ],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/estado/OCUPADO", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "estado", "OCUPADO"] } },
          "response": []
        },
        {
          "name": "Buscar por Zona y Estado (200)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 200', () => pm.response.code === 200);" ] } } ],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/zona/{{idZona}}/estado/OCUPADO", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "zona", "{{idZona}}", "estado", "OCUPADO"] } },
          "response": []
        },
        {
          "name": "Liberar (Estado DISPONIBLE 200)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 200', () => pm.response.code === 200);" ] } } ],
          "request": { "method": "PATCH", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/{{idEspacio}}/estado?estado=DISPONIBLE", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "{{idEspacio}}", "estado"], "query": [{ "key": "estado", "value": "DISPONIBLE" }] } },
          "response": []
        },
        {
          "name": "Desactivar Espacio (204)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 204', () => pm.response.code === 204);" ] } } ],
          "request": { "method": "PATCH", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/{{idEspacio}}/desactivar", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "{{idEspacio}}", "desactivar"] } },
          "response": []
        },
        {
          "name": "Activar Espacio (204)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 204', () => pm.response.code === 204);" ] } } ],
          "request": { "method": "PATCH", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/{{idEspacio}}/activar", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "{{idEspacio}}", "activar"] } },
          "response": []
        },
        {
          "name": "Listar DISPONIBLES (todos) (200)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 200', () => pm.response.code === 200);", "pm.test('es lista', () => Array.isArray(pm.response.json()));" ] } } ],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/disponibles", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "disponibles"] }, "description": "Lista todos los espacios activos en estado DISPONIBLE. Pensado para que el ticket sepa donde hay cupo." },
          "response": []
        },
        {
          "name": "Listar DISPONIBLES por zona y tipo (200)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 200', () => pm.response.code === 200);" ] } } ],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/disponibles?idZona={{idZona}}&tipo=AUTO", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "disponibles"], "query": [{ "key": "idZona", "value": "{{idZona}}" }, { "key": "tipo", "value": "AUTO" }] }, "description": "Filtra disponibles por zona y tipo de espacio (MOTO|AUTO|BUSETA). Ambos parametros son opcionales." },
          "response": []
        },
        {
          "name": "Verificar disponibilidad de un espacio (200)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 200', () => pm.response.code === 200);", "pm.test('trae campo disponible', () => pm.response.json().hasOwnProperty('disponible'));" ] } } ],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/{{idEspacio}}/disponibilidad", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "{{idEspacio}}", "disponibilidad"] }, "description": "Respuesta compacta {idEspacio, codigo, disponible, activo, estado}. disponible=true solo si esta activo y DISPONIBLE." },
          "response": []
        }
      ]
    },
    {
      "name": "3. Reglas de negocio y errores",
      "item": [
        {
          "name": "Crear Espacio sin tipo (400)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 400', () => pm.response.code === 400);" ] } } ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idZona\": \"{{idZona}}\",\n  \"descripcion\": \"Falta el tipo\"\n}" },
            "url": { "raw": "{{urlZonas}}/api/v1/espacios", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios"] }
          },
          "response": []
        },
        {
          "name": "Estado enum invalido (400)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 400', () => pm.response.code === 400);" ] } } ],
          "request": { "method": "PATCH", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/{{idEspacio}}/estado?estado=VOLANDO", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "{{idEspacio}}", "estado"], "query": [{ "key": "estado", "value": "VOLANDO" }], "description": "Enum inexistente -> manejado por GlobalExceptionHandler (TypeMismatch) -> 400." } },
          "response": []
        },
        {
          "name": "Obtener Espacio inexistente (404)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 404', () => pm.response.code === 404);" ] } } ],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/00000000-0000-0000-0000-000000000000", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "00000000-0000-0000-0000-000000000000"] } },
          "response": []
        },
        {
          "name": "Setup: Zona capacidad 1",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 201', () => pm.response.code === 201);", "pm.collectionVariables.set('idZonaCap', pm.response.json().idZona);" ] } } ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Zona CAP {{$timestamp}}\",\n  \"descripcion\": \"Capacidad 1 para probar el limite\",\n  \"tipo\": \"INTERNA\",\n  \"capacidad\": 1\n}" },
            "url": { "raw": "{{urlZonas}}/api/v1/zonas", "host": ["{{urlZonas}}"], "path": ["api", "v1", "zonas"] }
          },
          "response": []
        },
        {
          "name": "Llenar unico espacio (201)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 201', () => pm.response.code === 201);" ] } } ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idZona\": \"{{idZonaCap}}\",\n  \"descripcion\": \"Unico espacio permitido\",\n  \"tipo\": \"MOTO\"\n}" },
            "url": { "raw": "{{urlZonas}}/api/v1/espacios", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios"] }
          },
          "response": []
        },
        {
          "name": "Exceder capacidad (409)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 409', () => pm.response.code === 409);" ] } } ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idZona\": \"{{idZonaCap}}\",\n  \"descripcion\": \"Sobrepasa la capacidad\",\n  \"tipo\": \"MOTO\"\n}" },
            "url": { "raw": "{{urlZonas}}/api/v1/espacios", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios"] },
            "description": "La zona ya esta llena (capacidad 1) -> 409 'La zona alcanzo su capacidad maxima'."
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Limpieza",
      "item": [
        {
          "name": "Eliminar Espacio (204)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status 204', () => pm.response.code === 204);" ] } } ],
          "request": { "method": "DELETE", "header": [], "url": { "raw": "{{urlZonas}}/api/v1/espacios/{{idEspacio}}", "host": ["{{urlZonas}}"], "path": ["api", "v1", "espacios", "{{idEspacio}}"] } },
          "response": []
        }
      ]
    }
  ]
}
