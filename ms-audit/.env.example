PORT=3002

# Clave PUBLICA RSA (RS256) del emisor (usuarios). Solo sirve para VERIFICAR la
# firma; NO permite emitir/re-firmar tokens. Genera el valor con
# scripts/setup_jwt_keys.sh (escribe el .env real). Puede ser el PEM en base64
# o el PEM directo (multilinea).
JWT_PUBLIC_KEY=<base64-del-PEM-publico>
JWT_ISSUER=parqueadero

# RabbitMQ (ver docker-compose.yml raiz -> servicio "rabbitmq")
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=audit_queue
RABBITMQ_EXCHANGE=audit_exchange
# Entre comillas: sin ellas, dotenv trata "#" como inicio de comentario y
# trunca el valor a "audit." (rompe el binding con las routing keys reales).
RABBITMQ_ROUTING_KEY="audit.#"

# PostgreSQL unificado (ver docker-compose.yml raiz -> servicio "postgres", host 5433)
DB_HOST=localhost
DB_PORT=5433
DB_USER=audit_user
DB_PASSWORD=audit_pass
DB_NAME=audit_db

# Rate limiting (endpoints REST de consulta)
THROTTLE_TTL=60
THROTTLE_LIMIT=10
