# =====================================================================
# Plantilla de variables de entorno del sistema de parqueadero.
# Copia este archivo a ".env" y cambia los valores en produccion.
#   cp .env.example .env
# El archivo ".env" NO debe subirse al repositorio (ver .gitignore).
# docker compose lee ".env" automaticamente en este directorio.
# =====================================================================

# ---------- PostgreSQL (contenedor) ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ---------- RabbitMQ (contenedor) ----------
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ---------- Credenciales por microservicio (override en prod) ----------
# Los servicios Spring leen estas variables (application.yaml) con estos
# mismos nombres; aqui van los defaults de desarrollo.
# tickets:
DB_HOST=localhost
DB_PORT=5433
DB_NAME=tickets
DB_USER=tickets
DB_PASSWORD=tickets123
DDL_AUTO=update
JPA_SHOW_SQL=false

# ---------- RabbitMQ para los microservicios ----------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# ---------- JWT (clave publica de verificacion) ----------
JWT_PUBLIC_KEY=keys/jwt_public.pem
JWT_ISSUER=parqueadero
