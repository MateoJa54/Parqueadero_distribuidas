DB_HOST=localhost
DB_PORT=5433
DB_USUARIO=postgres
DB_CONTRASENA=postgres
DB_NOMBRE=vehiculos_db

# Clave PUBLICA RSA (RS256) del emisor (usuarios): solo VERIFICA la firma, no
# permite emitir/re-firmar tokens. Generar con scripts/setup_jwt_keys.sh.
JWT_PUBLIC_KEY=<base64-del-PEM-publico>
JWT_ISSUER=parqueadero
