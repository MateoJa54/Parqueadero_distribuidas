          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Otra\",\n  \"lastName\": \"Persona\",\n  \"dni\": \"1710034065\",\n  \"email\": \"otra@espe.edu.ec\",\n  \"phone\": \"0987654321\",\n  \"nationality\": \"Ecuatoriana\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/personas", "host": ["{{baseUrl}}"], "path": ["api", "v1", "personas"] },
        "description": "Repite el dni de la persona 01 -> 409 'Ya existe una persona con el dni: ...'."
