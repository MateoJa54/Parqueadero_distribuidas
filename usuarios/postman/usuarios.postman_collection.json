{
  "info": {
    "name": "Usuarios API - Parqueadero",
    "description": "Coleccion para probar la API de usuarios/roles (Spring Boot, puerto 8081). Incluye validacion real de cedula ecuatoriana y CRUD completo de personas, roles y usuarios. Los IDs se guardan automaticamente en variables de coleccion mediante los scripts de la pestania 'Tests'.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081", "type": "string" },
    { "key": "idPersona", "value": "", "type": "string" },
    { "key": "idUsuario", "value": "", "type": "string" },
    { "key": "idRol", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "00 - Health (debug si se cuelga)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/personas", "host": ["{{baseUrl}}"], "path": ["api", "v1", "personas"] },
        "description": "Si esta peticion no responde, la app NO esta levantada o el puerto es incorrecto. Debe devolver 200 y una lista (vacia [] al inicio)."
      },
      "response": []
    },
    {
      "name": "01 - Crear Persona (OK 201)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 201', () => pm.response.code === 201);",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('idPersona', body.id);",
              "console.log('idPersona guardado:', body.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ana\",\n  \"middleName\": \"Maria\",\n  \"lastName\": \"Lopez\",\n  \"dni\": \"1710034065\",\n  \"email\": \"ana.lopez@espe.edu.ec\",\n  \"phone\": \"0991112233\",\n  \"address\": \"Av. General Rumiñahui\",\n  \"nationality\": \"Ecuatoriana\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/personas", "host": ["{{baseUrl}}"], "path": ["api", "v1", "personas"] }
      },
      "response": []
    },
    {
      "name": "02 - Crear Persona DNI invalido (ERROR 400)",
      "request": {
