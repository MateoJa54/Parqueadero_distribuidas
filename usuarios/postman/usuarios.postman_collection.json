          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Pedro\",\n  \"lastName\": \"Suarez\",\n  \"dni\": \"12AB\",\n  \"email\": \"pedro@espe.edu.ec\",\n  \"phone\": \"0991112299\",\n  \"nationality\": \"Ecuatoriana\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/personas", "host": ["{{baseUrl}}"], "path": ["api", "v1", "personas"] },
        "description": "DNI con letras -> 400 con mensaje de cedula ecuatoriana invalida."
      },
      "response": []
    },
    {
